OLLAMA_MODEL=llama3.2
MAX_SUPERVISOR_ROUNDS=3

# ── Reflexion critic & plan-and-execute (both opt-in, off by default) ──────────
# CRITIC_ENABLED=true              # Reflexion self-critique loop (one extra LLM call/turn)
# PLANNER_ENABLED=true             # route via plan-and-execute planner with parallel fan-out
# PLANNER_MAX_REPLANS=2            # max replanning rounds per request on step failure

# ── Permissions ───────────────────────────────────────────────────────────────
# Roles: viewer (chat only) | analyst (chat + audit/upload) | admin (all, default)
ACTIVE_ROLE=admin
# JSON dict mapping api_key → role for multi-user / API access
# PERMISSION_KEYS={"sk-abc123":"analyst","sk-xyz789":"admin"}
PERMISSION_KEYS={}

# ── Application identity ──────────────────────────────────────────────────────
APP_NAME=AI Auditor          # displayed in UI, bot messages, and executor prompts
BRAND_NAME=                  # canonical brand name to enforce (empty = disabled)
DEFAULT_OWNER=               # fallback owner when doc author cannot be resolved
OWNER_USERNAMES=             # comma-separated owner usernames, e.g. alice,bob

# ── LLM provider ──────────────────────────────────────────────────────────────
# Any provider supported by LangChain's init_chat_model works with ZERO code
# changes. Set LLM_PROVIDER + the matching model/key below.
#   anthropic (default) · groq · ollama · openai · mistralai · google_genai · bedrock · …
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GROQ_API_KEY=
ROLE_PROVIDER_CRITIC=groq

# Fully local, NO API key: uncomment the two lines below (requires Ollama running).
#   curl -fsSL https://ollama.com/install.sh | sh   &&   ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2

# OpenAI or any OpenAI-compatible endpoint (vLLM, LM Studio, OpenRouter):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                 # set to your server's URL for compatible endpoints

# Any other provider — install langchain-<provider>, set its standard key env var,
# then pick the model with LLM_MODEL (or a per-role ROLE_MODEL_<ROLE>):
# LLM_PROVIDER=mistralai
# MISTRAL_API_KEY=...
# LLM_MODEL=mistral-large-latest

# ── Retrieval (agentic RAG) ──────────────────────────────────────────────────
# Pipeline: fetch → cross-encoder rerank → LLM relevance grade → rewrite+retry.
# RAG_RERANK=true                                  # second-stage cross-encoder reranking
# RAG_RERANK_MODEL=BAAI/bge-reranker-base          # CPU-friendly; bge-reranker-v2-m3 for max quality
# RAG_GRADE=true                                   # CRAG-style LLM relevance grading
# RAG_QUERY_REWRITE=true                           # rewrite + re-retrieve once if graded insufficient
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5           # local CPU embeddings (no service dependency)

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Analytics / PostgreSQL ────────────────────────────────────────────────────
# Set DB_ENABLED=true only when a PostgreSQL instance is reachable.
# When false (default), the Analytics tab shows a "not connected" message
# and makes zero network calls — safe for laptop / demo use.
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit
DB_USER=audit
DB_PASSWORD=             # set your real password in production

# ── MCP remote servers (optional) ────────────────────────────────────────────
# JSON list of remote HTTP MCP servers. Supported transports: sse | streamable_http
# MCP_HTTP_SERVERS=[{"name":"my-server","transport":"streamable_http","url":"https://example.com/mcp","headers":{"Authorization":"Bearer sk-..."}}]
MCP_HTTP_SERVERS=[]

# ── Telegram notifications (optional) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OWNERS=alice,bob         # comma-separated usernames
# TELEGRAM_ALICE_CHAT_ID=123456789  # one entry per owner listed above
# TELEGRAM_BOB_CHAT_ID=987654321
# TELEGRAM_DEFAULT_CHAT_ID=         # admin fallback when owner has no chat_id
